{
  "name": "final-project",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply finalproject_db --local",
    "db:migrate:remote": "wrangler d1 migrations apply finalproject_db --remote",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@fullcalendar/vue3": "^6.1.20",
    "@vueuse/core": "^14.3.0",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.18",
    "hono-rate-limiter": "^0.5.3",
    "pinia": "^3.0.4",
    "vue-router": "^5.0.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.36.4",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "drizzle-kit": "^0.31.10",
    "globals": "^17.6.0",
    "vite": "^8.0.12",
    "wrangler": "^4.90.1"
  }
}
